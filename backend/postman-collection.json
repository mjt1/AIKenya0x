              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Register a new extension agent. Returns JWT + agent profile.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Asha Wanjiru\",\n  \"email\": \"asha@digicow.co.ke\",\n  \"password\": \"changeme123\",\n  \"county\": \"Kakamega\",\n  \"cooperative\": \"Mumias Sugar Cooperative\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('token', json.token);",
                  "  if (json.agent && json.agent.id) pm.collectionVariables.set('agentId', json.agent.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
