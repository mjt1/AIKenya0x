# ── Featherless AI ────────────────────────────────────────────────────────────
FEATHERLESS_API_KEY=your_featherless_api_key
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1

# Primary model — fast, strong instruction-following (change to 70B for production)
#FEATHERLESS_CHAT_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
FEATHERLESS_CHAT_MODEL=Qwen/Qwen3-32B

# Heavier model used only for advisory generation (grounded Q&A)
# FEATHERLESS_ADVISORY_MODEL=meta-llama/Llama-3.3-70B-Instruct
FEATHERLESS_ADVISORY_MODEL=Qwen/Qwen3-32B

# ── Embeddings ────────────────────────────────────────────────────────────────
# sentence-transformers model (downloaded on first run; ~90 MB)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ── Service settings ──────────────────────────────────────────────────────────
APP_NAME=Suluhu AI Service
APP_VERSION=0.2.0
DEBUG=false
LOG_LEVEL=INFO

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=60

# LLM generation params
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
LLM_ADVISORY_MAX_TOKENS=2048

# Confidence thresholds
REFERRAL_CONFIDENCE_THRESHOLD=0.55   # below this → always refer
HIGH_RISK_AUTO_REFER=true            # CRITICAL severity always triggers referral
